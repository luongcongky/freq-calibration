{
  "name": "Demo Loop + If",
  "description": "Minh hoạ luồng điều khiển: lặp đo nhiều lần và rẽ nhánh theo giá trị đo. Mở bằng 📂, bấm ▶ CHẠY (MOCK).",
  "nodes": [
    {
      "type": "step",
      "action": "set_gate_time",
      "devices": ["CNT91"],
      "params": { "gate_time": 0.1 },
      "note": "Đặt gate 100 ms",
      "enabled": true
    },
    {
      "type": "loop",
      "count": 3,
      "note": "Đo tần số 3 lần",
      "enabled": true,
      "body": [
        {
          "type": "step",
          "action": "measure_frequency",
          "devices": ["CNT91"],
          "params": {},
          "note": "",
          "enabled": true
        }
      ]
    },
    {
      "type": "if",
      "note": "Rẽ nhánh theo tần số đo gần nhất",
      "enabled": true,
      "branches": [
        {
          "condition": { "kind": "measure", "device": "CNT91", "op": ">", "value": 1000000.0, "value2": 0.0, "status": "ok" },
          "enabled": true,
          "body": [
            {
              "type": "step",
              "action": "identify",
              "devices": ["CNT91"],
              "params": {},
              "note": "Tần số > 1 MHz -> nhận diện CNT91",
              "enabled": true
            }
          ]
        },
        {
          "condition": null,
          "enabled": true,
          "body": [
            {
              "type": "step",
              "action": "identify",
              "devices": ["N1913A"],
              "params": {},
              "note": "Ngược lại -> nhận diện máy công suất",
              "enabled": true
            }
          ]
        }
      ]
    }
  ]
}
