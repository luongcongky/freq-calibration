{
  "name": "Demo — Tính năng IF rẽ nhánh",
  "description": "Kịch bản minh hoạ tính năng IF:\n1. Bật RF (SMW200A) ở 1 GHz, -10 dBm.\n2. Đo công suất bằng E4418A.\n3. IF công suất >= -15 dBm → PASS (đạt yêu cầu).\n   ELSE (ngược lại) → tắt RF vì công suất quá thấp.",
  "nodes": [
    {
      "type": "step",
      "action": "set_rf_frequency",
      "devices": ["SMW200A"],
      "params": { "freq_hz": 1000000000.0 },
      "note": "Bước 1 — Đặt tần số RF = 1 GHz",
      "enabled": true
    },
    {
      "type": "step",
      "action": "set_rf_power",
      "devices": ["SMW200A"],
      "params": { "power_dbm": -10.0 },
      "note": "Bước 2 — Đặt mức công suất RF = -10 dBm",
      "enabled": true
    },
    {
      "type": "step",
      "action": "rf_on",
      "devices": ["SMW200A"],
      "params": {},
      "note": "Bước 3 — Bật RF output",
      "enabled": true
    },
    {
      "type": "step",
      "action": "wait",
      "devices": [],
      "params": { "seconds": 1.0 },
      "note": "Bước 4 — Chờ 1 giây để tín hiệu ổn định",
      "enabled": true
    },
    {
      "type": "step",
      "action": "measure_power",
      "devices": ["E4418A"],
      "params": {},
      "note": "Bước 5 — Đo công suất. Kết quả đo được dùng làm điều kiện cho IF bên dưới",
      "enabled": true
    },
    {
      "type": "if",
      "note": "Bước 6 — Rẽ nhánh theo kết quả đo công suất vừa rồi",
      "enabled": true,
      "branches": [
        {
          "condition": {
            "kind": "measure",
            "device": "E4418A",
            "op": ">=",
            "value": -15.0,
            "value2": 0.0,
            "status": "ok"
          },
          "enabled": true,
          "body": [
            {
              "type": "step",
              "action": "wait",
              "devices": [],
              "params": { "seconds": 0.1 },
              "note": "✅ PASS — Công suất đạt yêu cầu (>= -15 dBm). Ghi nhận kết quả và tiếp tục.",
              "enabled": true
            }
          ]
        },
        {
          "condition": null,
          "enabled": true,
          "body": [
            {
              "type": "step",
              "action": "rf_off",
              "devices": ["SMW200A"],
              "params": {},
              "note": "❌ FAIL — Công suất quá thấp (< -15 dBm). Tắt RF để bảo vệ thiết bị.",
              "enabled": true
            }
          ]
        }
      ]
    }
  ]
}
