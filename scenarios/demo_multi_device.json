{
  "name": "Demo đa thiết bị: counter + power meter",
  "description": "Kịch bản mẫu grid step-by-step. Mở bằng nút 📂 trong Scenario Builder, rồi ▶ CHẠY (MOCK).",
  "steps": [
    {
      "action": "identify",
      "devices": ["CNT91", "N1913A"],
      "params": {},
      "note": "Nhận diện đồng thời máy đếm và máy đo công suất",
      "enabled": true
    },
    {
      "action": "set_gate_time",
      "devices": ["CNT91"],
      "params": { "gate_time": 0.1 },
      "note": "Đặt gate 100 ms cho máy đếm",
      "enabled": true
    },
    {
      "action": "set_frequency",
      "devices": ["N1913A"],
      "params": { "freq_hz": 1000000000.0 },
      "note": "Đặt 1 GHz để power meter chọn đúng cal factor",
      "enabled": true
    },
    {
      "action": "wait",
      "devices": [],
      "params": { "seconds": 0.5 },
      "note": "Chờ ổn định",
      "enabled": true
    },
    {
      "action": "measure_frequency",
      "devices": ["CNT91"],
      "params": {},
      "note": "Đo tần số",
      "enabled": true
    },
    {
      "action": "measure_power",
      "devices": ["N1913A"],
      "params": {},
      "note": "Đo công suất",
      "enabled": true
    }
  ]
}
