{
  "name": "Đo độ nhạy (đầy đủ — vòng kín)",
  "description": "Bản ĐẦY ĐỦ dùng biến + tính toán + Loop-đến-khi (Phase 1-5): đo 3 lần lấy trung bình, tính sai số tương đối, lặp tăng công suất 0,5 dB/vòng tới khi sai số <= 1e-7 (tối đa 20 vòng). LƯU Ý: chạy MOCK thì máy đếm trả 0 nên không hội tụ (sẽ chạm max_iter) — đúng logic; trên MÁY THẬT sẽ hội tụ.",
  "nodes": [
    { "type": "step", "action": "set_var", "devices": [],
      "params": { "name": "f_set", "expr": "100000000" },
      "note": "Tần số đặt 100 MHz", "enabled": true },
    { "type": "step", "action": "set_var", "devices": [],
      "params": { "name": "p_base", "expr": "-5" },
      "note": "Công suất ban đầu -5 dBm", "enabled": true },
    { "type": "step", "action": "set_var", "devices": [],
      "params": { "name": "error", "expr": "1" },
      "note": "Khởi tạo sai số (để vòng until chạy lần đầu)", "enabled": true },

    { "type": "step", "action": "raw_scpi", "devices": ["SMW200A"],
      "params": { "__template__": "*RST", "__is_query__": false,
                  "__cmd_original__": "*RST", "__cmd_desc__": "Reset máy phát" },
      "note": "", "enabled": true },
    { "type": "step", "action": "raw_scpi", "devices": ["SMW200A"],
      "params": { "__template__": "SOUR{ch}:FREQ:CW {Hz} HZ", "__is_query__": false,
                  "__cmd_original__": "SOUR<ch>:FREQ:CW <Hz> HZ", "__cmd_desc__": "Đặt tần số CW",
                  "ch": 1, "Hz": "=f_set" },
      "note": "Tần số = f_set (biểu thức)", "enabled": true },
    { "type": "step", "action": "raw_scpi", "devices": ["SMW200A"],
      "params": { "__template__": "OUTP{ch}:STAT ON", "__is_query__": false,
                  "__cmd_original__": "OUTP<ch>:STAT ON", "__cmd_desc__": "Bật RF", "ch": 1 },
      "note": "", "enabled": true },

    { "type": "step", "action": "raw_scpi", "devices": ["53131A"],
      "params": { "__template__": "SENS:FREQ:ARM:STOP:SOUR DIG", "__is_query__": false,
                  "__cmd_original__": "SENS:FREQ:ARM:STOP:SOUR DIG", "__cmd_desc__": "Stop arm = digits" },
      "note": "", "enabled": true },
    { "type": "step", "action": "raw_scpi", "devices": ["53131A"],
      "params": { "__template__": "SENS:FREQ:ARM:STOP:DIG 8", "__is_query__": false,
                  "__cmd_original__": "SENS:FREQ:ARM:STOP:DIG 8", "__cmd_desc__": "8 digits" },
      "note": "", "enabled": true },

    { "type": "loop", "mode": "until", "count": 1, "max_iter": 20,
      "condition": { "kind": "expr", "expr": "error", "op": "<=", "value": 1e-07,
                     "value2": 0.0, "status": "ok", "device": "" },
      "note": "Lặp đến khi sai số <= 1e-7 (tăng công suất mỗi vòng)", "enabled": true,
      "body": [
        { "type": "step", "action": "raw_scpi", "devices": ["SMW200A"],
          "params": { "__template__": "SOUR{ch}:POW:POW {pw} dBm", "__is_query__": false,
                      "__cmd_original__": "SOUR<ch>:POW:POW <pw> dBm", "__cmd_desc__": "Đặt công suất",
                      "ch": 1, "pw": "=p_base + 0.5*($iter-1)" },
          "note": "Công suất tăng 0,5 dB mỗi vòng theo $iter", "enabled": true },
        { "type": "step", "action": "wait", "devices": [],
          "params": { "seconds": 2.0 }, "note": "Chờ ổn định sau đổi công suất", "enabled": true },
        { "type": "step", "action": "set_var", "devices": [],
          "params": { "name": "samples", "expr": "[]" },
          "note": "Reset list mẫu cho vòng này", "enabled": true },
        { "type": "loop", "mode": "count", "count": 3, "max_iter": 50, "condition": null,
          "note": "Đo 3 lần, cách 0,5 s", "enabled": true,
          "body": [
            { "type": "step", "action": "raw_scpi", "devices": ["53131A"],
              "params": { "__template__": "INIT", "__is_query__": false,
                          "__cmd_original__": "INIT", "__cmd_desc__": "Bắt đầu đo" },
              "note": "", "enabled": true },
            { "type": "step", "action": "raw_scpi", "devices": ["53131A"],
              "params": { "__template__": "FETC?", "__is_query__": true,
                          "__cmd_original__": "FETC?", "__cmd_desc__": "Đọc tần số (Hz)" },
              "note": "", "enabled": true },
            { "type": "step", "action": "collect", "devices": [],
              "params": { "var": "samples", "source": "$last" },
              "note": "Gom kết quả đo vào samples", "enabled": true },
            { "type": "step", "action": "wait", "devices": [],
              "params": { "seconds": 0.5 }, "note": "Cách nhau 0,5 s", "enabled": true }
          ] },
        { "type": "step", "action": "compute", "devices": [],
          "params": { "name": "f_avg", "expr": "avg(samples)" },
          "note": "Trung bình 3 lần đo", "enabled": true },
        { "type": "step", "action": "compute", "devices": [],
          "params": { "name": "error", "expr": "abs(f_avg - f_set)/f_set" },
          "note": "Sai số tương đối", "enabled": true }
      ] }
  ]
}
